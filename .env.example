# Copy to .env (or paste these into Portainer "Environment variables") and fill in real values.

# Postgres password used by both the database container and the API connection string.
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# JWT signing secret. Minimum 32 characters of random data.
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Single-user credentials (this app only allows one user — these define who logs in).
AUTH_EMAIL=
AUTH_PASSWORD=
